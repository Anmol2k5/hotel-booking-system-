{
  "name": "frontdesk",
  "version": "1.0.0",
  "description": "Hotel Front Desk Management System",
  "main": "src/main/index.js",
  "scripts": {
    "dev": "concurrently \"vite --config vite.renderer.config.ts\" \"wait-on http://localhost:5173 && electron .\"",
    "build": "vite build --config vite.renderer.config.ts && electron-builder",
    "preview": "vite preview --config vite.renderer.config.ts"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.105.3",
    "better-sqlite3": "^12.9.0",
    "date-fns": "^3.3.1",
    "lucide-react": "^0.344.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.22.0",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^8.2.2",
    "electron": "^29.1.0",
    "electron-builder": "^24.13.3",
    "typescript": "^5.3.3",
    "vite": "^5.1.4",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.hotelms.frontdesk",
    "productName": "Hotel Front Desk",
    "directories": {
      "output": "release"
    },
    "win": {
      "target": "nsis",
      "icon": "src/renderer/src/assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
